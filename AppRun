#!/bin/bash
# Make Qt aware of bundled fonts (for Japanese + CJK support)
export QT_FONTDIR="$APPDIR/usr/share/fonts/truetype"

# Resolve AppDir
HERE="$(dirname "$(readlink -f "$0")")"

# Force bundled Python runtime
export PYTHONHOME="$HERE/usr"
export PYTHONPATH="$HERE/usr/lib/python3.14/site-packages"

# Use local __pycache__ folder next to AppImage for runtime caching
export PYTHONPYCACHEPREFIX="$HERE/__pycache__"
mkdir -p "$PYTHONPYCACHEPREFIX"

# Forces CPU rendering for WSL to remove the error messages about mesa not being detected for GPU rendering
#export QT_QUICK_BACKEND=software
#export LIBGL_ALWAYS_SOFTWARE=1

exec "$HERE/usr/bin/python3" "$HERE/usr/app/rclone_GUI.py"
